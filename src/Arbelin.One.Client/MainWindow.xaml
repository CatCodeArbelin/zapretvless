<Window x:Class="Arbelin.One.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arbelin One"
        MinWidth="900"
        MinHeight="600"
        Width="1000"
        Height="650"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Arbelin One"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,12" />

            <TextBlock Text="Bootstrap ready"
                       FontSize="18"
                       Margin="0,0,0,24" />

            <Border BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Mode: Stopped" Margin="0,0,0,6" />
                    <TextBlock Text="Xray: not configured" Margin="0,0,0,6" />
                    <TextBlock Text="Zapret: not configured" Margin="0,0,0,6" />
                    <TextBlock Text="WinDivert: not configured" />
                </StackPanel>
            </Border>

            <WrapPanel Margin="0,0,0,20">
                <Button Content="Start VLESS"
                        Width="150"
                        Height="36"
                        Margin="0,0,12,12"
                        Click="OnBootstrapOnlyClick" />

                <Button Content="Start DPI Bypass"
                        Width="170"
                        Height="36"
                        Margin="0,0,12,12"
                        Click="OnBootstrapOnlyClick" />

                <Button Content="Start Hybrid"
                        Width="150"
                        Height="36"
                        Margin="0,0,12,12"
                        Click="OnBootstrapOnlyClick" />

                <Button Content="Stop All"
                        Width="130"
                        Height="36"
                        Margin="0,0,12,12"
                        Click="OnBootstrapOnlyClick" />
            </WrapPanel>

            <TextBlock x:Name="BootstrapNotice"
                       Text="PR-01 bootstrap mode. Runtime logic is not implemented yet."
                       TextWrapping="Wrap"
                       Foreground="#555555" />
        </StackPanel>
    </Grid>
</Window>
